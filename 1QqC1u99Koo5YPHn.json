    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "\nconst item = $input.item;\nconst j = item.json;\n\n// ======================================================\n// DADOS DE IDENTIFICAÇÃO\n// ======================================================\n\nj.phoneconnected =\n  j.phoneconnect ??\n  null;\n\nj.Phone =\n  j.Phone ??\n  j.phone ??\n  null;\n\nj.Nome =\n  j.Nome ??\n  j.contacts?.[0]?.profile?.name ??\n  null;\n\n// ======================================================\n// CONFIGURAÇÃO POR NÚMERO\n// ======================================================\n\nconst phonesConfig = {\n  \"1068535889684555\": {\n    acessToken: \"3EA6B3979B12E1B6EDC772620DC9C8F4\",\n    businessAccountID: \"1512857447000297\",\n    rotaAutenticacao:\n      \"https://tdev3-ag.icommercial002.inovamobil.com.br/api/chatbot\",\n    rotaDebitos:\n      \"https://tdev3-fat.icommercial002.inovamobil.com.br/api/debitos\",\n  },\n};\n\n// ======================================================\n// VALIDAÇÃO\n// ======================================================\n\nconst phoneConnected = (j.phoneconnect ?? \"\")\n  .toString()\n  .replace(/\\D+/g, \"\");\n\nconst selected = phonesConfig[phoneConnected];\n\nif (!selected) {\n  throw new Error(\n    `PhoneConnected (${phoneConnected || \"vazio\"}) não mapeado em phonesConfig`,\n  );\n}\n\nj.configuracoes = {\n  AcessToken: selected.acessToken,\n  BusinessAccountID: selected.businessAccountID,\n  PhoneConnected:phoneConnected\n};\n\n\nreturn item;"
      },
